{% extends 'base.html.twig' %}

{% block title %}Unités
{% endblock %}

{% block body %}

	<div class="fr-table" id="table-0-component">
		<div class="fr-table__wrapper">
			<div class="fr-table__container">
				<div class="fr-table__content">
					<table>
						<caption>
							Tableau des unités
						</caption>
						<thead>
							<tr>
								<th>Id</th>
								<th>Code</th>
								<th>Nom</th>
								<th></th>
							</tr>
						</thead>
						<tbody>
							{% for unite in unites %}
								<tr>
									<td>{{ unite.id }}</td>
									<td>{{ unite.code }}</td>
									<td>{{ unite.nom }}</td>
									<td>
										<a class="fr-btn fr-icon-eye-line fr-btn--icon-left fr-btn--tertiary" href="{{ path('app_unite_show', {'id': unite.id}) }}">Afficher</a>
										<a class="fr-btn fr-icon-edit-line fr-btn--icon-left fr-btn--tertiary" href="{{ path('app_unite_edit', {'id': unite.id}) }}">Éditer</a>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="4">Aucune entrée trouvée</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<a class="fr-btn fr-icon-add-line fr-btn--icon-left" href="{{ path('app_unite_new') }}">Créer une nouvelle unité</a>
{% endblock %}
