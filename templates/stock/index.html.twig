{% extends 'base.html.twig' %}

{% block title %}Stock rapide{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock') }}
{% endblock %}

{% block body %}
<div class="qs" id="qs-app">

    {# ── Tab bar ────────────────────────────────────────────────────────── #}

    <nav class="qs__tabs" role="tablist" aria-label="Fonctions">
        <button
            class="qs__tab qs__tab--active"
            id="tab-trouver"
            role="tab"
            aria-selected="true"
            aria-controls="panel-trouver"
        >
            <span class="qs__tab-icon" aria-hidden="true">&#128269;</span>
            <span class="qs__tab-label">Trouver</span>
            <kbd class="qs__tab-kbd" title="Raccourci : touche 1">1</kbd>
        </button>

        <button
            class="qs__tab"
            id="tab-ranger"
            role="tab"
            aria-selected="false"
            aria-controls="panel-ranger"
        >
            <span class="qs__tab-icon" aria-hidden="true">&#128229;</span>
            <span class="qs__tab-label">Ranger</span>
            <kbd class="qs__tab-kbd" title="Raccourci : touche 2">2</kbd>
        </button>

        <button
            class="qs__tab"
            id="tab-sortir"
            role="tab"
            aria-selected="false"
            aria-controls="panel-sortir"
        >
            <span class="qs__tab-icon" aria-hidden="true">&#128228;</span>
            <span class="qs__tab-label">Sortir</span>
            <kbd class="qs__tab-kbd" title="Raccourci : touche 3">3</kbd>
        </button>
    </nav>

    {# ── Panel : Trouver ────────────────────────────────────────────────── #}

    <div
        class="qs__panel"
        id="panel-trouver"
        role="tabpanel"
        aria-labelledby="tab-trouver"
    >
        <div class="qs__autocomplete">
            <input
                type="search"
                id="trouver-query"
                class="qs__input"
                placeholder="Rechercher un article (marque, modèle, description)…"
                autocomplete="off"
                aria-label="Rechercher un article"
                aria-autocomplete="list"
                aria-haspopup="listbox"
                aria-controls="trouver-dropdown"
                aria-expanded="false"
                autofocus
            />
            <ul
                class="qs__dropdown"
                id="trouver-dropdown"
                role="listbox"
                aria-label="Suggestions d'articles"
                hidden
            ></ul>
        </div>

        <div class="qs__loading" id="trouver-loading" hidden>
            <span class="qs__spinner" aria-hidden="true"></span>
            Recherche en cours…
        </div>

        <div class="qs__results" id="trouver-results" aria-live="polite"></div>
    </div>

    {# ── Panel : Ranger ─────────────────────────────────────────────────── #}

    <div
        class="qs__panel"
        id="panel-ranger"
        role="tabpanel"
        aria-labelledby="tab-ranger"
        hidden
    >
        {# Step 1 : search #}
        <div class="qs__step" id="ranger-step-search">
            <div class="qs__autocomplete">
                <input
                    type="search"
                    id="ranger-query"
                    class="qs__input"
                    placeholder="Quel article ranger ?"
                    autocomplete="off"
                    aria-label="Rechercher un article à ranger"
                    aria-autocomplete="list"
                    aria-haspopup="listbox"
                    aria-controls="ranger-dropdown"
                    aria-expanded="false"
                />
                <ul
                    class="qs__dropdown"
                    id="ranger-dropdown"
                    role="listbox"
                    aria-label="Suggestions d'articles"
                    hidden
                ></ul>
            </div>
        </div>

        {# Step 2 : location #}
        <div class="qs__step" id="ranger-step-location" hidden>
            <div class="qs__famille-badge" id="ranger-famille-badge">
                <span id="ranger-famille-label"></span>
                <button
                    class="qs__reset-btn"
                    id="ranger-reset"
                    type="button"
                    title="Changer d'article"
                    aria-label="Changer d'article"
                >&#x2715;</button>
            </div>

            <div class="qs__selects">
                <div class="qs__select-group">
                    <label class="qs__label" for="ranger-piece">Pièce</label>
                    <select id="ranger-piece" class="qs__select">
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="ranger-zone">Zone</label>
                    <select id="ranger-zone" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="ranger-rangement">Rangement</label>
                    <select id="ranger-rangement" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="ranger-emplacement">Emplacement</label>
                    <select id="ranger-emplacement" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__quantity-group">
                    <label class="qs__label" for="ranger-quantite">Quantité</label>
                    <input
                        type="number"
                        id="ranger-quantite"
                        class="qs__input qs__input--number"
                        value="1"
                        min="1"
                        aria-label="Quantité à ranger"
                    />
                </div>
            </div>

            <button class="qs__confirm-btn" id="ranger-confirm" type="button" disabled>
                <span class="qs__confirm-icon" aria-hidden="true">&#128229;</span>
                Ranger
            </button>
        </div>

        <div class="qs__feedback" id="ranger-feedback" role="alert" hidden></div>
    </div>

    {# ── Panel : Sortir ─────────────────────────────────────────────────── #}

    <div
        class="qs__panel"
        id="panel-sortir"
        role="tabpanel"
        aria-labelledby="tab-sortir"
        hidden
    >
        {# Step 1 : search #}
        <div class="qs__step" id="sortir-step-search">
            <div class="qs__autocomplete">
                <input
                    type="search"
                    id="sortir-query"
                    class="qs__input"
                    placeholder="Quel article sortir ?"
                    autocomplete="off"
                    aria-label="Rechercher un article à sortir"
                    aria-autocomplete="list"
                    aria-haspopup="listbox"
                    aria-controls="sortir-dropdown"
                    aria-expanded="false"
                />
                <ul
                    class="qs__dropdown"
                    id="sortir-dropdown"
                    role="listbox"
                    aria-label="Suggestions d'articles"
                    hidden
                ></ul>
            </div>
        </div>

        {# Step 2 : location #}
        <div class="qs__step" id="sortir-step-location" hidden>
            <div class="qs__famille-badge" id="sortir-famille-badge">
                <span id="sortir-famille-label"></span>
                <button
                    class="qs__reset-btn"
                    id="sortir-reset"
                    type="button"
                    title="Changer d'article"
                    aria-label="Changer d'article"
                >&#x2715;</button>
            </div>

            <div class="qs__selects">
                <div class="qs__select-group">
                    <label class="qs__label" for="sortir-piece">Pièce</label>
                    <select id="sortir-piece" class="qs__select">
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="sortir-zone">Zone</label>
                    <select id="sortir-zone" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="sortir-rangement">Rangement</label>
                    <select id="sortir-rangement" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__select-group">
                    <label class="qs__label" for="sortir-emplacement">Emplacement</label>
                    <select id="sortir-emplacement" class="qs__select" disabled>
                        <option value="">— Choisir —</option>
                    </select>
                </div>
                <div class="qs__quantity-group">
                    <label class="qs__label" for="sortir-quantite">Quantité</label>
                    <input
                        type="number"
                        id="sortir-quantite"
                        class="qs__input qs__input--number"
                        value="1"
                        min="1"
                        aria-label="Quantité à sortir"
                    />
                </div>
            </div>

            <button class="qs__confirm-btn qs__confirm-btn--danger" id="sortir-confirm" type="button" disabled>
                <span class="qs__confirm-icon" aria-hidden="true">&#128228;</span>
                Sortir
            </button>
        </div>

        <div class="qs__feedback" id="sortir-feedback" role="alert" hidden></div>
    </div>

</div>
{% endblock %}
