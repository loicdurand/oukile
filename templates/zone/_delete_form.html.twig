<form method="post" action="{{ path('oukile_zone_delete', {'id': zone.id}) }}" onsubmit="return confirm('Êtes vous sûr de vouloir supprimer cette zone?');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ zone.id) }}">
	<button class="fr-btn fr-btn--tertiary">Supprimer</button>
</form>
